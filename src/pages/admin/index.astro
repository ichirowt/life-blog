---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getThemeSettings, type SidebarNavId } from '../../lib/theme-settings';
import { createWithBase } from '../../utils/format';

const isDev = import.meta.env.DEV;
const base = import.meta.env.BASE_URL ?? '/';
const withBase = createWithBase(base);
const settingsEndpoint = withBase('/api/admin/settings/');

const navIdOrder: SidebarNavId[] = ['essay', 'bits', 'memo', 'archive', 'about'];
const navLabelFallback: Record<SidebarNavId, string> = {
  essay: '随笔',
  bits: '絮语',
  memo: '小记',
  archive: '归档',
  about: '关于'
};
const homeIntroMaxLength = 240;
const pageSubtitleMaxLength = 120;

const initialResolved = getThemeSettings();
const initialNavMap = new Map(
  initialResolved.settings.shell.nav.map((item) => [item.id, item])
);

const initialPayload = {
  settings: {
    ...initialResolved.settings,
    shell: {
      ...initialResolved.settings.shell,
      nav: navIdOrder.map((id, index) => {
        const current = initialNavMap.get(id);
        if (current) return current;
        return {
          id,
          label: navLabelFallback[id],
          visible: true,
          order: index + 1
        };
      })
    }
  },
  sources: initialResolved.sources
};

const bootstrapJson = JSON.stringify(initialPayload).replace(/</g, '\u003c');
---

<BaseLayout title="Theme Console" bodyClass="admin-page">
  <Fragment slot="head">
    <meta name="robots" content="noindex,nofollow" />
  </Fragment>

  {
    isDev ? (
      <section class="admin-console" data-admin-root data-settings-endpoint={settingsEndpoint}>
        <header class="page-header page-header--admin">
          <div class="admin-heading">
            <h1 class="page-title">Theme Console</h1>
            <span class="page-subtitle">主题设置</span>
          </div>
          <p id="admin-status" class="admin-status" data-state="idle">等待加载</p>
        </header>

        <p class="admin-hint">
          当前阶段仅开放受约束字段：<code>site</code> / <code>shell</code> / <code>home</code> /
          <code>page</code> / <code>ui</code>。保存后会写入 <code>src/data/settings/*.json</code>。
        </p>

        <p id="admin-dirty-banner" class="admin-banner" hidden>你有未保存更改，离开页面会触发提醒。</p>
        <p id="admin-error-banner" class="admin-banner admin-banner--error" hidden></p>

        <form id="admin-form" class="admin-form" novalidate>
          <fieldset class="admin-group">
            <legend>Site</legend>
            <div class="admin-grid">
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">站点标题</span>
                  <span class="admin-label__hint">（用于浏览器标题 / RSS / 分享）</span>
                </span>
                <input id="site-title" type="text" autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">默认语言</span>
                  <span class="admin-label__hint">（映射到 <code>&lt;html lang&gt;</code>）</span>
                </span>
                <input id="site-default-locale" type="text" autocomplete="off" />
              </label>
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">默认 SEO 描述</span>
                  <span class="admin-label__hint">（用于未单独设置 description 的页面）</span>
                </span>
                <textarea id="site-description" rows="3"></textarea>
              </label>
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">页脚版权行</span>
                  <span class="admin-label__hint">（布局会自动附加年份范围）</span>
                </span>
                <input id="site-footer-copyright" type="text" autocomplete="off" />
              </label>
            </div>

            <div class="admin-subgroup">
              <p class="admin-subtitle">Social Links</p>
              <div class="admin-grid">
                <label class="admin-field">
                  <span class="admin-label">
                    <span class="admin-label__main">GitHub 链接</span>
                  </span>
                  <input id="site-social-github" type="url" inputmode="url" autocomplete="off" />
                </label>
                <label class="admin-field">
                  <span class="admin-label">
                    <span class="admin-label__main">X / Twitter 链接</span>
                  </span>
                  <input id="site-social-x" type="url" inputmode="url" autocomplete="off" />
                </label>
                <label class="admin-field">
                  <span class="admin-label">
                    <span class="admin-label__main">Email</span>
                  </span>
                  <input id="site-social-email" type="email" inputmode="email" autocomplete="off" />
                </label>
                <label class="admin-toggle-row">
                  <input id="site-social-rss" type="checkbox" />
                  <span>显示 RSS 链接（固定指向站内 /rss.xml）</span>
                </label>
              </div>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend>Sidebar</legend>
            <div class="admin-grid">
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">侧栏站点名</span>
                  <span class="admin-label__hint">（显示在左侧站点标题）</span>
                </span>
                <input id="shell-brand-title" type="text" autocomplete="off" />
              </label>
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">侧栏引用文案</span>
                  <span class="admin-label__hint">（支持换行显示）</span>
                </span>
                <textarea id="shell-quote" rows="4"></textarea>
              </label>
            </div>

            <div class="admin-subgroup">
              <p class="admin-subtitle">Sidebar 导航（仅既有项）</p>
              <div class="admin-nav-grid">
                <div class="admin-nav-header" aria-hidden="true">
                  <span>页面 ID</span>
                  <span>页面名称</span>
                  <span>位置排序</span>
                  <span>是否展示</span>
                </div>
                {
                  navIdOrder.map((id, index) => (
                    <div class="admin-nav-row" data-nav-id={id}>
                      <p class="admin-nav-id">
                        <code>{id}</code>
                      </p>
                      <label class="admin-field admin-nav-field admin-nav-field--name">
                        <span class="sr-only">{id} 页面名称</span>
                        <input data-nav-field="label" type="text" autocomplete="off" />
                      </label>
                      <label class="admin-field admin-nav-field admin-nav-field--order">
                        <span class="sr-only">{id} 位置排序</span>
                        <input data-nav-field="order" type="number" min="1" step="1" value={index + 1} />
                      </label>
                      <label class="admin-toggle">
                        <input data-nav-field="visible" type="checkbox" aria-label={`${id} 是否显示`} />
                        <span>展示</span>
                      </label>
                    </div>
                  ))
                }
              </div>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend>Home</legend>
            <div class="admin-grid">
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">首页导语主文案</span>
                </span>
                <textarea id="home-intro-lead" rows="3" maxlength={homeIntroMaxLength}></textarea>
              </label>
              <label class="admin-field admin-field--full">
                <span class="admin-label">
                  <span class="admin-label__main">首页导语补充文案</span>
                  <span class="admin-label__hint">（后方固定附带归档 / 随笔链接）</span>
                </span>
                <textarea id="home-intro-more" rows="2" maxlength={homeIntroMaxLength}></textarea>
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">Hero 预置</span>
                </span>
                <select id="home-hero-preset">
                  <option value="default">default</option>
                  <option value="minimal">minimal</option>
                  <option value="none">none</option>
                </select>
              </label>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend>Inner Pages</legend>
            <div class="admin-grid">
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">随笔副标题</span>
                  <span class="admin-label__hint">（动态计数 / RSS 固定输出）</span>
                </span>
                <input id="page-essay-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">归档副标题</span>
                  <span class="admin-label__hint">（动态计数 / RSS 固定输出）</span>
                </span>
                <input id="page-archive-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">絮语副标题</span>
                </span>
                <input id="page-bits-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">小记副标题</span>
                  <span class="admin-label__hint">（留空则回退 memo frontmatter）</span>
                </span>
                <input id="page-memo-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
              <label class="admin-field">
                <span class="admin-label">
                  <span class="admin-label__main">关于页副标题</span>
                  <span class="admin-label__hint">（可留空）</span>
                </span>
                <input id="page-about-subtitle" type="text" maxlength={pageSubtitleMaxLength} autocomplete="off" />
              </label>
            </div>

            <div class="admin-subgroup">
              <p class="admin-subtitle">Bits 默认作者</p>
              <div class="admin-grid">
                <label class="admin-field">
                  <span class="admin-label">
                    <span class="admin-label__main">默认作者名</span>
                  </span>
                  <input id="page-bits-author-name" type="text" autocomplete="off" />
                </label>
                <label class="admin-field">
                  <span class="admin-label">
                    <span class="admin-label__main">默认头像</span>
                    <span class="admin-label__hint">（相对路径）</span>
                  </span>
                  <input id="page-bits-author-avatar" type="text" autocomplete="off" />
                </label>
              </div>
            </div>
          </fieldset>

          <fieldset class="admin-group">
            <legend>Reading / Code</legend>
            <div class="admin-stack">
              <label class="admin-toggle-row">
                <input id="ui-code-line-numbers" type="checkbox" />
                <span>显示代码行号（仅映射全局 data-line-numbers）</span>
              </label>
              <label class="admin-toggle-row">
                <input id="ui-reading-entry" type="checkbox" />
                <span>显示阅读模式入口（不改变“状态不持久化”策略）</span>
              </label>
            </div>
          </fieldset>
        </form>

        <div class="admin-actions">
          <button id="admin-validate" class="admin-btn" type="button">检查配置</button>
          <button id="admin-reset" class="admin-btn admin-btn--ghost" type="button">重置更改</button>
          <button id="admin-save" class="admin-btn admin-btn--muted" type="button">保存</button>
        </div>

        <script id="admin-bootstrap" type="application/json" is:inline set:html={bootstrapJson}></script>
      </section>
    ) : (
      <section class="admin-console admin-console--readonly">
        <header class="page-header page-header--admin">
          <div class="admin-heading">
            <h1 class="page-title">Theme Console</h1>
            <span class="page-subtitle">主题设置</span>
          </div>
        </header>
        <p class="admin-hint">
          当前页面仅用于本地开发配置。根据 Phase 1 边界，生产环境不提供可写后台。
        </p>
      </section>
    )
  }

  {
    isDev ? (
      <script is:inline>
        (() => {
  const root = document.querySelector('[data-admin-root]');
  if (!root) return;

  const endpoint = root.getAttribute('data-settings-endpoint') || '/api/admin/settings/';
  const NAV_IDS = ['essay', 'bits', 'memo', 'archive', 'about'];
  const HERO_PRESETS = new Set(['default', 'minimal', 'none']);
  const LOCALE_RE = /^[A-Za-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$/;
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const GITHUB_HOSTS = ['github.com'];
  const X_HOSTS = ['x.com', 'twitter.com'];
  const HOME_INTRO_MAX_LENGTH = 240;
  const PAGE_SUBTITLE_MAX_LENGTH = 120;

  const form = document.getElementById('admin-form');
  const statusEl = document.getElementById('admin-status');
  const dirtyBanner = document.getElementById('admin-dirty-banner');
  const errorBanner = document.getElementById('admin-error-banner');
  const validateBtn = document.getElementById('admin-validate');
  const resetBtn = document.getElementById('admin-reset');
  const saveBtn = document.getElementById('admin-save');
  const bootstrapEl = document.getElementById('admin-bootstrap');

  if (!form || !statusEl || !dirtyBanner || !errorBanner || !validateBtn || !resetBtn || !saveBtn || !bootstrapEl) {
    return;
  }

  const inputSiteTitle = document.getElementById('site-title');
  const inputSiteDescription = document.getElementById('site-description');
  const inputSiteDefaultLocale = document.getElementById('site-default-locale');
  const inputSiteFooterCopyright = document.getElementById('site-footer-copyright');
  const inputSiteSocialGithub = document.getElementById('site-social-github');
  const inputSiteSocialX = document.getElementById('site-social-x');
  const inputSiteSocialEmail = document.getElementById('site-social-email');
  const inputSiteSocialRss = document.getElementById('site-social-rss');
  const inputShellBrandTitle = document.getElementById('shell-brand-title');
  const inputShellQuote = document.getElementById('shell-quote');
  const inputHomeIntroLead = document.getElementById('home-intro-lead');
  const inputHomeIntroMore = document.getElementById('home-intro-more');
  const inputPageEssaySubtitle = document.getElementById('page-essay-subtitle');
  const inputPageArchiveSubtitle = document.getElementById('page-archive-subtitle');
  const inputPageBitsSubtitle = document.getElementById('page-bits-subtitle');
  const inputPageMemoSubtitle = document.getElementById('page-memo-subtitle');
  const inputPageAboutSubtitle = document.getElementById('page-about-subtitle');
  const inputPageBitsAuthorName = document.getElementById('page-bits-author-name');
  const inputPageBitsAuthorAvatar = document.getElementById('page-bits-author-avatar');
  const inputHeroPreset = document.getElementById('home-hero-preset');
  const inputCodeLineNumbers = document.getElementById('ui-code-line-numbers');
  const inputReadingEntry = document.getElementById('ui-reading-entry');

  if (
    !inputSiteTitle ||
    !inputSiteDescription ||
    !inputSiteDefaultLocale ||
    !inputSiteFooterCopyright ||
    !inputSiteSocialGithub ||
    !inputSiteSocialX ||
    !inputSiteSocialEmail ||
    !inputSiteSocialRss ||
    !inputShellBrandTitle ||
    !inputShellQuote ||
    !inputHomeIntroLead ||
    !inputHomeIntroMore ||
    !inputPageEssaySubtitle ||
    !inputPageArchiveSubtitle ||
    !inputPageBitsSubtitle ||
    !inputPageMemoSubtitle ||
    !inputPageAboutSubtitle ||
    !inputPageBitsAuthorName ||
    !inputPageBitsAuthorAvatar ||
    !inputHeroPreset ||
    !inputCodeLineNumbers ||
    !inputReadingEntry
  ) {
    return;
  }

  const getNavRows = () => Array.from(root.querySelectorAll('[data-nav-id]'));
  const deepClone = (value) => JSON.parse(JSON.stringify(value));

  const normalizeMultiline = (value) => value.replace(/\r\n/g, '\n');
  const normalizeOptionalSingleLine = (value) => {
    const normalized = normalizeMultiline(value).trim();
    return normalized || null;
  };
  const normalizeEmail = (value) => value.replace(/^mailto:/i, '').trim();
  const parseOrder = (value, fallback) => {
    const next = Number.parseInt(value, 10);
    return Number.isFinite(next) ? next : fallback;
  };
  const isAllowedHttpsUrl = (value, hosts) => {
    try {
      const parsed = new URL(value);
      if (parsed.protocol !== 'https:') return false;
      const hostname = parsed.hostname.toLowerCase();
      return hosts.some((host) => hostname === host || hostname === `www.${host}` || hostname.endsWith(`.${host}`));
    } catch {
      return false;
    }
  };

  let baseline = null;
  let isDirty = false;
  let isSaving = false;

  const setStatus = (state, message) => {
    statusEl.dataset.state = state;
    statusEl.textContent = message;
  };

  const setErrors = (errors) => {
    if (!errors.length) {
      errorBanner.hidden = true;
      errorBanner.textContent = '';
      return;
    }
    errorBanner.hidden = false;
    errorBanner.textContent = errors.join('；');
  };

  const setDirty = (next) => {
    isDirty = next;
    dirtyBanner.hidden = !next;
  };

  const setSaving = (next) => {
    isSaving = next;
    saveBtn.disabled = next;
    saveBtn.textContent = next ? '保存中...' : '保存';
  };

  const canonicalize = (settings) => {
    const next = deepClone(settings);
    next.shell.nav = next.shell.nav
      .filter((item) => NAV_IDS.includes(item.id))
      .sort((a, b) => {
        if (a.order !== b.order) return a.order - b.order;
        return NAV_IDS.indexOf(a.id) - NAV_IDS.indexOf(b.id);
      });
    return next;
  };

  const collectSettings = () => {
    const nav = getNavRows().map((row, index) => {
      const id = row.getAttribute('data-nav-id');
      const labelInput = row.querySelector('[data-nav-field="label"]');
      const orderInput = row.querySelector('[data-nav-field="order"]');
      const visibleInput = row.querySelector('[data-nav-field="visible"]');
      const fallbackOrder = index + 1;
      return {
        id: id || '',
        label: (labelInput?.value || '').trim(),
        order: parseOrder(orderInput?.value || '', fallbackOrder),
        visible: Boolean(visibleInput?.checked)
      };
    });

    return {
      site: {
        title: inputSiteTitle.value.trim(),
        description: normalizeMultiline(inputSiteDescription.value).trim(),
        defaultLocale: inputSiteDefaultLocale.value.trim(),
        footer: {
          copyright: inputSiteFooterCopyright.value.trim()
        },
        socialLinks: {
          github: inputSiteSocialGithub.value.trim() || null,
          x: inputSiteSocialX.value.trim() || null,
          email: normalizeEmail(inputSiteSocialEmail.value.trim()) || null,
          rss: Boolean(inputSiteSocialRss.checked)
        }
      },
      shell: {
        brandTitle: inputShellBrandTitle.value.trim(),
        quote: normalizeMultiline(inputShellQuote.value).trim(),
        nav
      },
      home: {
        introLead: normalizeMultiline(inputHomeIntroLead.value).trim(),
        introMore: normalizeMultiline(inputHomeIntroMore.value).trim(),
        heroPresetId: inputHeroPreset.value
      },
      page: {
        essay: {
          subtitle: normalizeOptionalSingleLine(inputPageEssaySubtitle.value)
        },
        archive: {
          subtitle: normalizeOptionalSingleLine(inputPageArchiveSubtitle.value)
        },
        bits: {
          subtitle: normalizeOptionalSingleLine(inputPageBitsSubtitle.value),
          defaultAuthor: {
            name: inputPageBitsAuthorName.value.trim(),
            avatar: inputPageBitsAuthorAvatar.value.trim()
          }
        },
        memo: {
          subtitle: normalizeOptionalSingleLine(inputPageMemoSubtitle.value)
        },
        about: {
          subtitle: normalizeOptionalSingleLine(inputPageAboutSubtitle.value)
        }
      },
      ui: {
        codeBlock: {
          showLineNumbers: Boolean(inputCodeLineNumbers.checked)
        },
        readingMode: {
          showEntry: Boolean(inputReadingEntry.checked)
        }
      }
    };
  };

  const applySettings = (settings) => {
    inputSiteTitle.value = settings.site.title || '';
    inputSiteDescription.value = settings.site.description || '';
    inputSiteDefaultLocale.value = settings.site.defaultLocale || '';
    inputSiteFooterCopyright.value = settings.site.footer?.copyright || '';
    inputSiteSocialGithub.value = settings.site.socialLinks?.github || '';
    inputSiteSocialX.value = settings.site.socialLinks?.x || '';
    inputSiteSocialEmail.value = settings.site.socialLinks?.email || '';
    inputSiteSocialRss.checked = Boolean(settings.site.socialLinks?.rss);
    inputShellBrandTitle.value = settings.shell.brandTitle || '';
    inputShellQuote.value = settings.shell.quote || '';
    inputHomeIntroLead.value = settings.home.introLead || '';
    inputHomeIntroMore.value = settings.home.introMore || '';
    inputPageEssaySubtitle.value = settings.page.essay?.subtitle || '';
    inputPageArchiveSubtitle.value = settings.page.archive?.subtitle || '';
    inputPageBitsSubtitle.value = settings.page.bits?.subtitle || '';
    inputPageMemoSubtitle.value = settings.page.memo?.subtitle || '';
    inputPageAboutSubtitle.value = settings.page.about?.subtitle || '';
    inputPageBitsAuthorName.value = settings.page.bits?.defaultAuthor?.name || '';
    inputPageBitsAuthorAvatar.value = settings.page.bits?.defaultAuthor?.avatar || '';
    inputHeroPreset.value = settings.home.heroPresetId || 'default';
    inputCodeLineNumbers.checked = Boolean(settings.ui?.codeBlock?.showLineNumbers);
    inputReadingEntry.checked = Boolean(settings.ui?.readingMode?.showEntry);

    const navMap = new Map((settings.shell.nav || []).map((item) => [item.id, item]));
    getNavRows().forEach((row, index) => {
      const id = row.getAttribute('data-nav-id');
      const current = navMap.get(id) || {};
      const labelInput = row.querySelector('[data-nav-field="label"]');
      const orderInput = row.querySelector('[data-nav-field="order"]');
      const visibleInput = row.querySelector('[data-nav-field="visible"]');
      if (labelInput) labelInput.value = (current.label || '').trim();
      if (orderInput) orderInput.value = String(current.order ?? (index + 1));
      if (visibleInput) visibleInput.checked = Boolean(current.visible);
    });
  };

  const validateSettings = (settings) => {
    const errors = [];

    if (!settings.site.title) errors.push('站点标题不能为空');
    if (!settings.site.description) errors.push('站点描述不能为空');
    if (!settings.site.defaultLocale) {
      errors.push('默认语言不能为空');
    } else if (!LOCALE_RE.test(settings.site.defaultLocale)) {
      errors.push('默认语言格式无效（示例：zh-CN）');
    }
    if (!settings.site.footer?.copyright) {
      errors.push('页脚版权行不能为空');
    } else if (settings.site.footer.copyright.includes('\n') || settings.site.footer.copyright.includes('\r')) {
      errors.push('页脚版权行只允许单行文本');
    } else if (settings.site.footer.copyright.length > 120) {
      errors.push('页脚版权行不能超过 120 个字符');
    }

    if (settings.site.socialLinks?.github && !isAllowedHttpsUrl(settings.site.socialLinks.github, GITHUB_HOSTS)) {
      errors.push('GitHub 链接只允许 https://github.com/... ');
    }
    if (settings.site.socialLinks?.x && !isAllowedHttpsUrl(settings.site.socialLinks.x, X_HOSTS)) {
      errors.push('X / Twitter 链接只允许 https://x.com/... 或 https://twitter.com/... ');
    }
    if (settings.site.socialLinks?.email && !EMAIL_RE.test(normalizeEmail(settings.site.socialLinks.email))) {
      errors.push('Email 必须是合法邮箱地址');
    }
    if (typeof settings.site.socialLinks?.rss !== 'boolean') {
      errors.push('RSS 显示开关必须是布尔值');
    }

    if (!settings.shell.brandTitle) errors.push('侧栏站点名不能为空');
    if (!settings.shell.quote) errors.push('侧栏引用文案不能为空');

    if (!settings.home.introLead) {
      errors.push('首页导语主文案不能为空');
    } else if (settings.home.introLead.length > HOME_INTRO_MAX_LENGTH) {
      errors.push('首页导语主文案不能超过 ' + HOME_INTRO_MAX_LENGTH + ' 个字符');
    }

    if (!settings.home.introMore) {
      errors.push('首页导语补充文案不能为空');
    } else if (settings.home.introMore.length > HOME_INTRO_MAX_LENGTH) {
      errors.push('首页导语补充文案不能超过 ' + HOME_INTRO_MAX_LENGTH + ' 个字符');
    }

    const pageSubtitleMap = [
      ['essay', settings.page.essay?.subtitle, '随笔副标题'],
      ['archive', settings.page.archive?.subtitle, '归档副标题'],
      ['bits', settings.page.bits?.subtitle, '絮语副标题'],
      ['memo', settings.page.memo?.subtitle, '小记副标题'],
      ['about', settings.page.about?.subtitle, '关于页副标题']
    ];

    pageSubtitleMap.forEach(([, subtitle, label]) => {
      if (subtitle == null) return;
      if (typeof subtitle !== 'string') {
        errors.push(label + ' 必须是字符串或留空');
        return;
      }
      if (subtitle.includes('\n') || subtitle.includes('\r')) {
        errors.push(label + ' 只允许单行文本');
      }
      if (subtitle.length > PAGE_SUBTITLE_MAX_LENGTH) {
        errors.push(label + ' 不能超过 ' + PAGE_SUBTITLE_MAX_LENGTH + ' 个字符');
      }
    });

    if (!settings.page.bits?.defaultAuthor?.name) {
      errors.push('Bits 默认作者名不能为空');
    }
    if (settings.page.bits?.defaultAuthor?.avatar) {
      if (settings.page.bits.defaultAuthor.avatar.startsWith('/')) {
        errors.push('Bits 默认头像必须是相对路径，不要以 / 开头');
      }
      if (/^[A-Za-z]+:\/\//.test(settings.page.bits.defaultAuthor.avatar)) {
        errors.push('Bits 默认头像当前仅允许相对路径，不允许 URL');
      }
    }

    if (!HERO_PRESETS.has(settings.home.heroPresetId)) {
      errors.push('Hero 预置只允许 default/minimal/none');
    }

    const nav = Array.isArray(settings.shell.nav) ? settings.shell.nav : [];
    if (nav.length !== NAV_IDS.length) {
      errors.push('Sidebar 导航项数量必须与既有导航一致');
    }

    const seenIds = new Set();
    const seenOrders = new Set();
    nav.forEach((item) => {
      if (!NAV_IDS.includes(item.id)) errors.push('存在非法导航项 ID：' + item.id);
      if (seenIds.has(item.id)) errors.push('导航项 ID 重复：' + item.id);
      seenIds.add(item.id);

      if (!item.label) errors.push('导航项 ' + item.id + ' 的显示名称不能为空');
      if (!Number.isInteger(item.order) || item.order < 1 || item.order > 999) {
        errors.push('导航项 ' + item.id + ' 的位置排序必须为 1-999 的整数');
      }
      if (seenOrders.has(item.order)) {
        errors.push('位置排序不能重复：' + item.order);
      }
      seenOrders.add(item.order);
      if (typeof item.visible !== 'boolean') {
        errors.push('导航项 ' + item.id + ' 的 visible 必须是布尔值');
      }
    });

    return errors;
  };

  const refreshDirty = () => {
    if (!baseline) return;
    const current = canonicalize(collectSettings());
    setDirty(JSON.stringify(current) !== JSON.stringify(baseline));
  };

  const loadPayload = (payload, source) => {
    if (!payload || typeof payload !== 'object' || !payload.settings) {
      setStatus('error', '返回数据格式无效');
      return;
    }
    const normalized = canonicalize(payload.settings);
    baseline = normalized;
    applySettings(normalized);
    setErrors([]);
    setDirty(false);
    setStatus('ready', source === 'remote' ? '已同步最新配置' : '已载入初始配置');
  };

  const loadBootstrap = () => {
    try {
      const payload = JSON.parse(bootstrapEl.textContent || '{}');
      loadPayload(payload, 'bootstrap');
    } catch (error) {
      setStatus('error', '初始化数据解析失败');
      console.error(error);
    }
  };

  const loadFromApi = async () => {
    setStatus('loading', '正在读取 /api/admin/settings');
    try {
      const response = await fetch(endpoint, {
        method: 'GET',
        headers: { Accept: 'application/json' },
        cache: 'no-store'
      });
      if (!response.ok) {
        throw new Error('HTTP ' + response.status);
      }
      const payload = await response.json();
      loadPayload(payload, 'remote');
    } catch (error) {
      setStatus('warn', '接口读取失败，继续使用初始配置');
      console.warn(error);
    }
  };

  form.addEventListener('input', refreshDirty);
  form.addEventListener('change', refreshDirty);

  validateBtn.addEventListener('click', () => {
    const current = canonicalize(collectSettings());
    const errors = validateSettings(current);
    setErrors(errors);
    if (errors.length) {
      setStatus('error', '校验未通过');
      return;
    }
    setStatus('ok', '校验通过，可直接保存');
  });

  resetBtn.addEventListener('click', () => {
    if (!baseline) return;
    applySettings(deepClone(baseline));
    setErrors([]);
    setDirty(false);
    setStatus('ready', '已重置为最近一次加载值');
  });

  saveBtn.addEventListener('click', async () => {
    if (isSaving) return;
    const current = canonicalize(collectSettings());
    const errors = validateSettings(current);
    setErrors(errors);
    if (errors.length) {
      setStatus('error', '保存前校验失败');
      return;
    }

    setSaving(true);
    setStatus('loading', '正在保存到 src/data/settings/*.json');

    try {
      const requestBody = JSON.stringify(current);
      if (!requestBody) {
        setErrors(['保存请求体为空，请刷新页面后重试']);
        setStatus('error', '保存失败');
        return;
      }

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          Accept: 'application/json',
          'Content-Type': 'application/json; charset=utf-8'
        },
        cache: 'no-store',
        body: requestBody
      });

      const payload = await response.json().catch(() => null);
      if (!response.ok || !payload?.ok) {
        const serverErrors = Array.isArray(payload?.errors) ? payload.errors : ['保存失败，请稍后重试'];
        setErrors(serverErrors);
        if (response.status === 404) {
          setStatus('error', '当前环境不允许写入（仅 DEV 可写）');
        } else {
          setStatus('error', '保存失败');
        }
        return;
      }

      if (payload?.payload?.settings) {
        loadPayload(payload.payload, 'remote');
        setStatus('ok', '保存成功，已刷新最新配置');
      } else {
        baseline = current;
        setDirty(false);
        setStatus('ok', '保存成功');
      }
      setErrors([]);
    } catch (error) {
      console.error(error);
      setErrors(['保存请求失败，请检查本地服务日志']);
      setStatus('error', '保存失败');
    } finally {
      setSaving(false);
    }
  });

  window.addEventListener('beforeunload', (event) => {
    if (!isDirty) return;
    event.preventDefault();
  });

  loadBootstrap();
  void loadFromApi();
})();
      </script>
    ) : null
  }
</BaseLayout>
